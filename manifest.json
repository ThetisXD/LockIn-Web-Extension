{
  "manifest_version": 3,
  "name": "Lock-In | Focus App",
  "version": "1.0",
  "description": "Stay focused and less distracted by blacklisting tabs and managing time",  
  "permissions": [
    "tabs",
    "storage",
    "sidePanel"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Open Lock-In App"
  },

  "side_panel": {
    "default_path": "index.html"
  },


  "icons":
  {
    "32": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  }


}